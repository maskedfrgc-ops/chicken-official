rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /pfps/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /uploads/{uid}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
