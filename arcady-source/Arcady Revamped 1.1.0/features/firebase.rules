rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && userDoc(request.auth.uid).data.role in ['admin', 'owner'];
    }

    function isOwner() {
      return signedIn() && userDoc(request.auth.uid).data.role == 'owner';
    }

    function canManageServerData(data) {
      return signedIn() && (
        isAdmin() ||
        data.ownerId == request.auth.uid
      );
    }

    function notBanned() {
      return signedIn() && !(userDoc(request.auth.uid).data.banned == true);
    }

    match /meta/{docId} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSelf(resource.data.uid) || isOwner();
      allow update: if false;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if isOwner();
    }

    match /servers/{serverId} {
      allow read: if signedIn();
      allow create: if notBanned() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if canManageServerData(resource.data);

      match /channels/{channelId} {
        allow read: if signedIn();
        allow create, update, delete: if canManageServerData(get(/databases/$(database)/documents/servers/$(serverId)).data);

        match /messages/{messageId} {
          allow read: if signedIn();
          allow create: if notBanned()
            && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if notBanned() && (
            resource.data.authorId == request.auth.uid || isAdmin()
          );
        }
      }
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /siteAdminState/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /siteAdminAnnouncements/{announcementId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /siteAdminPolls/{pollId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;

      match /votes/{voteId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if false;
      }
    }

    match /dms/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create, update: if signedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/dms/$(conversationId)).data.members;
        allow create: if notBanned()
          && request.resource.data.authorId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/dms/$(conversationId)).data.members;
        allow update, delete: if false;
      }
    }
  }
}
