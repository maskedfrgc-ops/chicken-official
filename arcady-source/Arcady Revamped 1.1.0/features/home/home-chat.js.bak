  // bluemojiCatalog: Bluemoji from bluemoji.io (Webflow CDN). Re-fetch pages to refresh.

  function fileSlugFromEmojiUrl(url) {
    var base = String(url || "").split("/").pop() || "";
    return String(base.replace(/\.(png|gif|jpe?g|webp)$/i, "")).toLowerCase();
  }

  var slackmojiBySlug = {};
  bluemojiCatalog.forEach(function (entry) {
    var slug = fileSlugFromEmojiUrl(entry.url);
    if (slug && !slackmojiBySlug[slug]) {
      slackmojiBySlug[slug] = { url: entry.url, name: entry.name };
    }
  });

  function readStickerSendMode() {
    try {
      return sessionStorage.getItem("arcadyStickerSendMode") === "inline" ? "inline" : "box";
    } catch (error) {
      return "box";
    }
  }

  const messageLimit = 60;
  const maxImageBytes = 750 * 1024;
  const maxAvatarBytes = 96 * 1024;
  const maxAvatarFileBytes = 512 * 1024;
  const avatarDisplaySize = 72;
  const xpPerLevel = 100;
  const typingPresenceTtl = 4200;
  const nickStyleStorageKey = "arcadyHomeChatNickStyle";
  const nickFontKeyToStack = {
    fredoka: "'Fredoka', sans-serif",
    roboto: "'Roboto', sans-serif",
    playfair: "'Playfair Display', serif",
    mono: "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace",
    system: "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
  };
  const nickEffectSlugs = ["none", "glow", "shimmer", "pulse", "rainbow"];
  const nameTagEffectSlugs = ["none", "glow", "shimmer", "pulse", "rainbow"];
  const reactionOptions = [
    { key: "like", emoji: "👍", label: "Like" },
    { key: "love", emoji: "❤️", label: "Love" },
    { key: "laugh", emoji: "😂", label: "Laugh" },
    { key: "fire", emoji: "🔥", label: "Fire" }
  ];
  const protectedNickname = decodeValue("QXJjYWR5");
  const protectedNicknameKey = String(protectedNickname || "").trim().toLowerCase();

  const state = {
    db: null,
    ready: false,
    sending: false,
    messages: [],
    selectedImage: null,
    selectedGifUrl: "",
    selectedGifName: "",
    activeChannel: "general",
    dmTargetNickname: "",
    dmTargetNicknameKey: "",
    activeGroupId: "",
    groupMenuOpen: false,
    groups: {},
    groupMenuCloseTimer: 0,
    gifLibrary: [],
    gifLibraryLoaded: false,
    gifsLoading: false,
    gifPanelOpen: false,
    typingUsers: {},
    typingRefreshTimer: 0,
    typingClearTimer: 0,
    typingActive: false,
    ownerUnlocked: readOwnerAccess(),
    deviceId: getDeviceId(),
    xpProfiles: {},
    adminGrants: {},
    selectedProfileKey: "",
    chatBans: {
      devices: {},
      nicknames: {}
    },
    chatTimeouts: {},
    replyDraft: null,
    mentionOpen: false,
    mentionHighlight: 0,
    mentionItems: [],
    mentionRange: null,
    stickerSendMode: readStickerSendMode(),
    emojiOpen: false,
    emojiHighlight: 0,
    emojiItems: [],
    emojiRange: null,
    nameTagDefs: {},
    userNameTags: {}
  };

  const els = {};

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  function init() {
    cacheElements();
    if (!els.panel || !els.feed || !els.input || !els.sendButton) {
      return;
    }
    ensureGifUi();
    cacheElements();
    ensureComposeMetaUi();
    cacheElements();
    ensureReplyAndMentionUi();
    cacheElements();

    bindUi();
    syncStickerModeRadios();
    initAvatarControls();
    initNicknameStylePanel();
    renderMessages();
    renderGifLibrary();
    syncGifPickerUi();
    renderTypingIndicator();
    renderReplyBarUI();
    updateComposerState();
    updateSelectedMediaMeta();
    setStatus(readNickname() ? "Connecting homepage chat..." : "Set your nickname above to start chatting.");
    initFirebase();
  }

  function cacheElements() {
    els.panel = document.getElementById("home-chat-panel");
    els.feed = document.getElementById("home-chat-feed");
    els.empty = document.getElementById("home-chat-empty");
    els.status = document.getElementById("home-chat-status");
    els.input = document.getElementById("home-chat-input");
    els.imageInput = document.getElementById("home-chat-image-input");
    els.attach = document.getElementById("home-chat-attach");
    els.sendButton = document.getElementById("home-chat-send");
    els.fileMeta = document.getElementById("home-chat-file");
    els.channelSelect = document.getElementById("home-chat-channel-select");
    els.targetLabel = document.getElementById("home-chat-target-label");
    els.targetInput = document.getElementById("home-chat-target-input");
    els.groupSelectLabel = document.getElementById("home-chat-group-select-label");
    els.groupSelect = document.getElementById("home-chat-group-select");
    els.createGroupButton = document.getElementById("home-chat-create-group");
    els.channelInfo = document.getElementById("home-chat-channel-info");
    els.groupButton = document.getElementById("home-chat-group-button");
    els.groupMenu = document.getElementById("home-chat-group-menu");
    els.compose = els.panel ? els.panel.querySelector(".home-chat-compose") : null;
    els.composeRow = els.panel ? els.panel.querySelector(".home-chat-compose-row") : null;
    els.composeMeta = els.panel ? els.panel.querySelector(".home-chat-compose-meta") : null;
    els.gifToggle = document.getElementById("home-chat-gif-toggle");
    els.gifPanel = document.getElementById("home-chat-gif-panel");
    els.gifGrid = document.getElementById("home-chat-gif-grid");
    
    els.bluemojiGrid = document.getElementById("home-chat-bluemoji-grid");
    els.gifStatus = document.getElementById("home-chat-gif-status");
    els.typing = document.getElementById("home-chat-typing");
    els.refreshButton = document.getElementById("home-chat-refresh");
    els.replyBar = document.getElementById("home-chat-reply-bar");
    els.replyName = document.querySelector("#home-chat-reply-bar .home-chat-reply-name");
    els.replySnippet = document.querySelector("#home-chat-reply-bar .home-chat-reply-snippet");
    els.replyCancel = document.getElementById("home-chat-reply-cancel");
    els.inputWrap = document.querySelector(".home-chat-input-wrap");
    els.mentionList = document.getElementById("home-chat-mention-suggest");
    els.emojiList = document.getElementById("home-chat-emoji-suggest");
  }

  function buildHomeChatMediaPanelInnerHtml() {
    return [
      '<div class="home-chat-gif-toolbar">',
      '  <div class="home-chat-gif-title">Media &amp; stickers</div>',
      '  <div class="home-chat-gif-status" id="home-chat-gif-status">Open Media to load the libraries.</div>',
      '</div>',
      '<div class="home-chat-sticker-mode-bar" role="group" aria-label="How to send stickers">',
      '  <span class="home-chat-sticker-mode-label">Send stickers as</span>',
      '  <label class="home-chat-sticker-mode-opt"><input type="radio" name="home-chat-sticker-mode" id="home-chat-sticker-mode-box" value="box" checked> Large (box)</label>',
      '  <label class="home-chat-sticker-mode-opt"><input type="radio" name="home-chat-sticker-mode" id="home-chat-sticker-mode-inline" value="inline"> Inline 32×32</label>',
      '</div>',
      '<div class="home-chat-gif-section">',
      '  <div class="home-chat-gif-subtitle">Arcady library</div>',
      '  <div class="home-chat-gif-grid" id="home-chat-gif-grid">',
      '    <div class="home-chat-gif-empty">Open Media to load the Arcady library.</div>',
      '  </div>',
      '</div>',
      
      '<div class="home-chat-gif-section home-chat-bluemoji-section">',
      '  <div class="home-chat-gif-subtitle">Bluemoji <a class="home-chat-slackmojis-source" href="' + bluemojiCatalogSource + '" target="_blank" rel="noopener noreferrer">bluemoji.io</a></div>',
      '  <div class="home-chat-gif-grid home-chat-bluemoji-grid" id="home-chat-bluemoji-grid">',
      '    <div class="home-chat-gif-empty">Open Media to load Bluemoji from bluemoji.io.</div>',
      '  </div>',
      '</div>'
    ].join("");
  }

  function ensureGifUi() {
    if (!els.compose || !els.composeRow) {
      return;
    }

    if (!document.getElementById("home-chat-gif-toggle")) {
      const gifToggle = document.createElement("button");
      gifToggle.id = "home-chat-gif-toggle";
      gifToggle.className = "home-chat-gif-toggle";
      gifToggle.type = "button";
      gifToggle.textContent = "Media";

      if (els.sendButton && els.sendButton.parentNode === els.composeRow) {
        els.composeRow.insertBefore(gifToggle, els.sendButton);
      } else {
        els.composeRow.appendChild(gifToggle);
      }
    }

    let gifPanel = document.getElementById("home-chat-gif-panel");
    if (!gifPanel) {
      gifPanel = document.createElement("div");
      gifPanel.className = "home-chat-gif-panel";
      gifPanel.id = "home-chat-gif-panel";
      gifPanel.innerHTML = buildHomeChatMediaPanelInnerHtml();
      els.compose.appendChild(gifPanel);
      syncStickerModeRadios();
      return;
    }

    if (!document.getElementById("home-chat-bluemoji-grid") || !document.getElementById("home-chat-sticker-mode-box")) {
      gifPanel.innerHTML = buildHomeChatMediaPanelInnerHtml();
    }
    syncStickerModeRadios();
  }

  function ensureComposeMetaUi() {
    if (!els.panel || !els.feed || !els.compose) {
      return;
    }
    if (document.getElementById("home-chat-typing")) {
      return;
    }
    const bar = document.createElement("div");
    bar.id = "home-chat-typing";
    bar.className = "home-chat-typing-bar";
    bar.setAttribute("aria-live", "polite");
    bar.setAttribute("aria-atomic", "true");
    bar.hidden = true;
    els.panel.insertBefore(bar, els.compose);
  }

  function ensureReplyAndMentionUi() {
    if (!els.compose || !els.composeRow || !els.input) {
      return;
    }
    if (!document.getElementById("home-chat-reply-bar")) {
      const replyBar = document.createElement("div");
      replyBar.id = "home-chat-reply-bar";
      replyBar.className = "home-chat-reply-bar";
      replyBar.hidden = true;
      replyBar.innerHTML =
        '<div class="home-chat-reply-inner">' +
        '<div class="home-chat-reply-preview">' +
        '<span class="home-chat-reply-label">Replying to</span> ' +
        '<strong class="home-chat-reply-name"></strong>' +
        '<span class="home-chat-reply-snippet"></span>' +
        "</div>" +
        '<button type="button" class="home-chat-reply-cancel" id="home-chat-reply-cancel" aria-label="Cancel reply">×</button>' +
        "</div>";
      els.compose.insertBefore(replyBar, els.composeRow);
    }
    if (els.input.parentNode === els.composeRow && !els.composeRow.querySelector(".home-chat-input-wrap")) {
      const wrap = document.createElement("div");
      wrap.className = "home-chat-input-wrap";
      const list = document.createElement("div");
      list.id = "home-chat-mention-suggest";
      list.className = "home-chat-mention-suggest";
      list.hidden = true;
      list.setAttribute("role", "listbox");
      els.composeRow.insertBefore(wrap, els.input);
      wrap.appendChild(els.input);
      wrap.appendChild(list);
      const emojiList = document.createElement("div");
      emojiList.id = "home-chat-emoji-suggest";
      emojiList.className = "home-chat-emoji-suggest";
      emojiList.hidden = true;
      emojiList.setAttribute("role", "listbox");
      emojiList.setAttribute("aria-label", "Emoji suggestions");
      wrap.appendChild(emojiList);
    } else {
      const wrap = els.composeRow.querySelector(".home-chat-input-wrap");
      if (wrap && !document.getElementById("home-chat-emoji-suggest")) {
        const emojiList = document.createElement("div");
        emojiList.id = "home-chat-emoji-suggest";
        emojiList.className = "home-chat-emoji-suggest";
        emojiList.hidden = true;
        emojiList.setAttribute("role", "listbox");
        emojiList.setAttribute("aria-label", "Emoji suggestions");
        wrap.appendChild(emojiList);
      }
    }
  }

  function syncStickerModeRadios() {
    var box = document.getElementById("home-chat-sticker-mode-box");
    var inlineEl = document.getElementById("home-chat-sticker-mode-inline");
    if (!box || !inlineEl) {
      return;
    }
    if (state.stickerSendMode === "inline") {
      inlineEl.checked = true;
      box.checked = false;
    } else {
      box.checked = true;
      inlineEl.checked = false;
    }
  }

  function bindUi() {
    els.sendButton.addEventListener("click", sendMessage);
    if (els.refreshButton) {
      els.refreshButton.addEventListener("click", function () {
        refreshChatFeed();
      });
    }
    els.input.addEventListener("input", handleDraftInput);
    els.feed.addEventListener("click", handleFeedActionClick);
    els.input.addEventListener("keydown", handleComposerKeydown);
    els.input.addEventListener("blur", clearTypingSoon);
    els.imageInput.addEventListener("change", handleImageSelection);
    if (els.gifToggle) {
      els.gifToggle.addEventListener("click", toggleGifPanel);
    }
    if (els.gifPanel) {
      els.gifPanel.addEventListener("click", handleGifGridClick);
      els.gifPanel.addEventListener("change", function (event) {
        const t = event.target;
        if (t && t.name === "home-chat-sticker-mode") {
          state.stickerSendMode = t.value === "inline" ? "inline" : "box";
          try {
            sessionStorage.setItem("arcadyStickerSendMode", state.stickerSendMode);
          } catch (error) {}
          updateSelectedMediaMeta();
        }
      });
    }
    if (els.emojiList) {
      els.emojiList.addEventListener("click", function (event) {
        const btn = event.target.closest("[data-emoji-pick]");
        if (btn) {
          event.preventDefault();
          applyEmojiPick(btn.getAttribute("data-emoji-pick"));
        }
      });
    }
    if (els.tabs) {
      els.tabs.addEventListener("click", handleChannelTabClick);
    }
    if (els.channelSelect) {
      els.channelSelect.addEventListener("change", handleChannelSelectChange);
    }
    if (els.targetInput) {
      els.targetInput.addEventListener("input", function () {
        state.dmTargetNickname = String(els.targetInput.value || "").trim().slice(0, 24);
        state.dmTargetNicknameKey = normalizeNicknameKey(state.dmTargetNickname);
        updateComposerState();
      });
    }
    if (els.groupSelect) {
      els.groupSelect.addEventListener("change", function () {
        state.activeGroupId = String(els.groupSelect.value || "").trim();
        updateComposerState();
        renderChannelInfo();
      });
    }
    if (els.createGroupButton) {
      els.createGroupButton.addEventListener("click", createGroup);
    }
    if (els.groupButton && els.groupMenu) {
      els.groupButton.addEventListener("mouseenter", openGroupMenu);
      els.groupDropdownAnchor = els.groupMenu;
      els.groupButton.addEventListener("focus", openGroupMenu);
      els.groupButton.addEventListener("blur", scheduleCloseGroupMenu);
      els.groupButton.addEventListener("mouseleave", scheduleCloseGroupMenu);
      els.groupMenu.addEventListener("mouseenter", openGroupMenu);
      els.groupMenu.addEventListener("mouseleave", scheduleCloseGroupMenu);
      els.groupMenu.addEventListener("click", handleGroupMenuClick);
    }
    document.addEventListener("keydown", handleGlobalComposerShortcut);
    document.addEventListener("mousedown", handleDocumentPointerForMention, true);
    document.addEventListener("visibilitychange", handleVisibilityChange);
    if (els.replyCancel) {
      els.replyCancel.addEventListener("click", clearReplyDraft);
    }
    if (els.mentionList) {
      els.mentionList.addEventListener("click", function (event) {
        const btn = event.target.closest("[data-mention-pick]");
        if (btn) {
          event.preventDefault();
          applyMentionPick(btn.getAttribute("data-mention-pick"));
        }
      });
    }
    window.addEventListener("pagehide", clearTypingPresence);
    window.addEventListener("beforeunload", clearTypingPresence);
    window.addEventListener("arcady:nickname-change", function () {
      hideMentionSuggest();
      hideEmojiSuggest();
      syncNicknameAvatarPreview();
      updateComposerState();
      renderMessages(false);
      renderTypingIndicator();
      syncTypingPresence();
      setStatus(readNickname() ? (state.ready ? "Chat live. Say something." : "Connecting homepage chat...") : "Set your nickname above to start chatting.");
    });
    window.addEventListener("arcady:nick-style-change", function () {
      renderMessages(false);
      renderTypingIndicator();
    });
    window.addEventListener("arcady:avatar-change", function () {
      syncNicknameAvatarPreview();
      renderMessages(false);
    });
    window.addEventListener("arcady:owner-access-change", function (event) {
      state.ownerUnlocked = !!(event && event.detail && event.detail.unlocked);
      renderMessages(false);
    });
    window.addEventListener("storage", function (event) {
      if (event.key === "arcadyVisitorNickname") {
        updateComposerState();
        renderMessages(false);
        renderTypingIndicator();
        syncTypingPresence();
        if (!readNickname()) {
          clearTypingPresence();
        }
      } else if (event.key === "arcadyOwnerUnlocked") {
        state.ownerUnlocked = readOwnerAccess();
        renderMessages(false);
      } else if (event.key === "arcadyVisitorAvatar") {
        syncNicknameAvatarPreview();
        renderMessages(false);
      } else if (event.key === nickStyleStorageKey) {
        renderMessages(false);
        renderTypingIndicator();
      }
    });
    window.addEventListener("arcady:home-chat-refresh", refreshChatFeed);
  }

  function handleChannelTabClick(event) {
    const button = event.target.closest("[data-chat-tab]");
    if (!button) {
      return;
    }
    const selected = String(button.getAttribute("data-chat-tab") || "general");
    state.activeChannel = selected;
    if (els.tabs) {
      els.tabs.querySelectorAll("[data-chat-tab]").forEach(function (tab) {
        tab.classList.toggle("is-active", tab === button);
      });
    }
    if (els.channelSelect) {
      els.channelSelect.value = selected;
    }
    if (selected === "group") {
      if (!state.activeGroupId) {
        state.activeGroupId = getDefaultGroupId() || "";
      }
      updateGroupSelectOptions();
    }
    renderChannelInfo();
    renderMessages(false);
  }

  function handleChannelSelectChange(event) {
    state.activeChannel = String(event.target.value || "general");
    if (els.tabs) {
      els.tabs.querySelectorAll("[data-chat-tab]").forEach(function (tab) {
        tab.classList.toggle("is-active", tab.getAttribute("data-chat-tab") === state.activeChannel);
      });
    }
    if (state.activeChannel === "group") {
      if (!state.activeGroupId) {
        state.activeGroupId = getDefaultGroupId() || "";
      }
      updateGroupSelectOptions();
    }
    renderChannelInfo();
    renderMessages(false);
  }

  function openGroupMenu() {
    if (!els.groupMenu || !els.groupButton) {
      return;
    }
    window.clearTimeout(state.groupMenuCloseTimer);
    renderGroupMenu();
    els.groupMenu.hidden = false;
    els.groupButton.setAttribute("aria-expanded", "true");
  }

  function scheduleCloseGroupMenu() {
    window.clearTimeout(state.groupMenuCloseTimer);
    state.groupMenuCloseTimer = window.setTimeout(closeGroupMenu, 180);
  }

  function closeGroupMenu() {
    if (!els.groupMenu || !els.groupButton) {
      return;
    }
    els.groupMenu.hidden = true;
    els.groupButton.setAttribute("aria-expanded", "false");
  }

  function handleGroupMenuClick(event) {
    const selectButton = event.target.closest("[data-chat-group-select]");
    if (selectButton) {
      event.preventDefault();
      const groupId = String(selectButton.getAttribute("data-chat-group-select") || "");
      if (groupId) {
        state.activeChannel = "group";
        state.activeGroupId = groupId;
        if (els.channelSelect) {
          els.channelSelect.value = "group";
        }
        renderChannelInfo();
        renderMessages(false);
      }
      closeGroupMenu();
      return;
    }

    const acceptButton = event.target.closest("[data-chat-group-accept]");
    if (acceptButton) {
      event.preventDefault();
      const groupId = String(acceptButton.getAttribute("data-chat-group-accept") || "");
      acceptGroupInvite(groupId);
      closeGroupMenu();
      return;
    }

    const manageButton = event.target.closest("[data-chat-group-manage]");
    if (manageButton) {
      event.preventDefault();
      const groupId = String(manageButton.getAttribute("data-chat-group-manage") || "");
      manageGroup(groupId);
      return;
    }

    const leaveButton = event.target.closest("[data-chat-group-leave]");
    if (leaveButton) {
      event.preventDefault();
      const groupId = String(leaveButton.getAttribute("data-chat-group-leave") || "");
      leaveGroup(groupId);
      closeGroupMenu();
      return;
    }
  }

  function renderGroupMenu() {
    if (!els.groupMenu) {
      return;
    }

    const groups = getCurrentUserGroups();
    if (!groups.length) {
      els.groupMenu.innerHTML = '<div class="home-chat-group-empty">No groups yet. Create one to get started.</div>';
      return;
    }

    const owned = groups.filter(isGroupOwner);
    const member = groups.filter(function (group) {
      return !isGroupOwner(group) && isGroupMember(group);
    });
    const invited = groups.filter(function (group) {
      return !isGroupMember(group) && isGroupInvite(group);
    });

    const items = [];
    if (owned.length) {
      items.push('<div class="home-chat-group-section">Owned groups</div>');
      owned.forEach(function (group) {
        items.push(
          '<button type="button" class="home-chat-group-item" data-chat-group-select="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + '</button>' +
          '<button type="button" class="home-chat-group-action" data-chat-group-manage="' + escapeAttribute(group.id) + '">Manage</button>'
        );
      });
    }
    if (member.length) {
      items.push('<div class="home-chat-group-section">Groups</div>');
      member.forEach(function (group) {
        items.push(
          '<button type="button" class="home-chat-group-item" data-chat-group-select="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + '</button>' +
          '<button type="button" class="home-chat-group-action" data-chat-group-leave="' + escapeAttribute(group.id) + '">Leave</button>'
        );
      });
    }
    if (invited.length) {
      items.push('<div class="home-chat-group-section">Invites</div>');
      invited.forEach(function (group) {
        items.push(
          '<button type="button" class="home-chat-group-item" data-chat-group-select="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + ' (Invite)</button>' +
          '<button type="button" class="home-chat-group-action" data-chat-group-accept="' + escapeAttribute(group.id) + '">Accept invite</button>'
        );
      });
    }

    els.groupMenu.innerHTML = items.join("");
  }

  function normalizeGroupRecord(id, raw) {
    if (!id || !raw || typeof raw !== "object") {
      return null;
    }
    return {
      id: String(id || "").trim(),
      name: String(raw.name || "Unnamed group").trim(),
      ownerDeviceId: String(raw.ownerDeviceId || "").trim(),
      ownerNickname: String(raw.ownerNickname || "Owner").trim(),
      createdAt: Number(raw.createdAt || 0),
      members: typeof raw.members === "object" && raw.members ? raw.members : {},
      invites: typeof raw.invites === "object" && raw.invites ? raw.invites : {}
    };
  }

  function getCurrentUserGroups() {
    const selfKey = getNicknameKey();
    return Object.keys(state.groups || {}).map(function (id) {
      return normalizeGroupRecord(id, state.groups[id]);
    }).filter(function (group) {
      return group && (isGroupOwner(group) || isGroupMember(group) || isGroupInvite(group));
    }).sort(function (a, b) {
      return String(a.name || "").localeCompare(String(b.name || ""), undefined, { sensitivity: "base" });
    });
  }

  function isGroupOwner(group) {
    return !!(group && group.ownerDeviceId && group.ownerDeviceId === state.deviceId);
  }

  function isGroupMember(group) {
    return !!(group && group.members && group.members[state.deviceId]);
  }

  function isGroupInvite(group) {
    const selfKey = getNicknameKey();
    return !!(group && group.invites && group.invites[selfKey]);
  }

  function getDefaultGroupId() {
    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });
    return groups.length ? groups[0].id : "";
  }

  function isDirectMessageVisibleToCurrentUser(message) {
    if (!message) {
      return false;
    }
    if (canModerateChatLikeOwner()) {
      return true;
    }
    const selfKey = getNicknameKey();
    if (!selfKey) {
      return false;
    }
    const senderKey = normalizeNicknameKey(message.nicknameKey || message.nickname);
    if (senderKey === selfKey || message.deviceId === state.deviceId) {
      return true;
    }
    const recipientKey = normalizeNicknameKey(message.recipientNicknameKey || message.recipientNickname);
    if (recipientKey === selfKey || message.recipientDeviceId === state.deviceId) {
      return true;
    }
    return false;
  }

  function renderChannelInfo() {
    if (!els.channelInfo) {
      return;
    }
    if (state.activeChannel === "dm") {
      if (state.dmTargetNickname) {
        els.channelInfo.textContent = "Direct messages to " + state.dmTargetNickname + ". Only you and the recipient can see these if the recipient is a matching nickname.";
      } else {
        els.channelInfo.textContent = "Direct Message mode: type a nickname to send a private message.";
      }
      return;
    }
    if (state.activeChannel === "group") {
      const group = state.activeGroupId ? normalizeGroupRecord(state.activeGroupId, state.groups[state.activeGroupId]) : null;
      if (group && isGroupMember(group)) {
        els.channelInfo.textContent = "Group chat: " + group.name + ". Messages are visible only inside this group.";
      } else if (group && isGroupInvite(group)) {
        els.channelInfo.textContent = "You have an invite for " + group.name + ". Accept it from the group menu.";
      } else {
        els.channelInfo.textContent = "Group chat mode: select a group or create one to begin.";
      }
      return;
    }
    els.channelInfo.textContent = "Public chat: all users can see messages here.";
  }

  function updateGroupSelectOptions() {
    if (!els.groupSelect) {
      return;
    }

    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });

    if (!groups.length) {
      els.groupSelect.innerHTML = '<option value="">No groups available</option>';
      els.groupSelect.disabled = true;
      return;
    }

    const html = [
      '<option value="">Choose a group...</option>'
    ].concat(groups.map(function (group) {
      return '<option value="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + '</option>';
    }));
    els.groupSelect.innerHTML = html.join("");
    els.groupSelect.disabled = false;
    if (state.activeGroupId && groups.some(function (group) { return group.id === state.activeGroupId; })) {
      els.groupSelect.value = state.activeGroupId;
    } else {
      state.activeGroupId = groups.length ? groups[0].id : "";
      els.groupSelect.value = state.activeGroupId;
    }
  }

  async function createGroup() {
    const nickname = readNickname();
    if (!nickname) {
      setStatus("Save a nickname above first.");
      return;
    }
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot create a group right now.");
      return;
    }

    const groupName = String(prompt("Group name:", "My Group") || "").trim().slice(0, 40);
    if (!groupName) {
      return;
    }

    const inviteNames = String(prompt("Optional invite nicknames, comma-separated:", "") || "").trim();
    const groupRef = state.db.ref(groupPath).push();
    if (!groupRef || !groupRef.key) {
      setStatus("Unable to create group at the moment.");
      return;
    }

    const groupId = groupRef.key;
    const payload = {
      id: groupId,
      name: groupName,
      ownerDeviceId: state.deviceId,
      ownerNickname: nickname,
      createdAt: Date.now(),
      members: {},
      invites: {}
    };
    payload.members[state.deviceId] = true;

    if (inviteNames) {
      inviteNames.split(",").map(function (value) {
        return String(value || "").trim().slice(0, 24);
      }).filter(Boolean).forEach(function (invite) {
        const key = normalizeNicknameKey(invite);
        if (key && key !== getNicknameKey()) {
          payload.invites[key] = true;
        }
      });
    }

    try {
      await groupRef.set(payload);
      state.activeChannel = "group";
      state.activeGroupId = groupId;
      if (els.channelSelect) {
        els.channelSelect.value = "group";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Group created: " + groupName + ". Use the group menu to invite or manage it.");
    } catch (error) {
      console.error("Arcady create group failed:", error);
      setStatus("Could not create group right now.");
    }
  }

  async function acceptGroupInvite(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot accept invites.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupInvite(group)) {
      setStatus("Invite not found.");
      return;
    }
    const selfKey = getNicknameKey();
    const update = {};
    update["members/" + state.deviceId] = true;
    update["invites/" + selfKey] = null;
    try {
      await state.db.ref(groupPath + "/" + group.id).update(update);
      state.activeChannel = "group";
      state.activeGroupId = group.id;
      if (els.channelSelect) {
        els.channelSelect.value = "group";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Joined group " + group.name + ".");
    } catch (error) {
      console.error("Arcady accept group invite failed:", error);
      setStatus("Could not join the group.");
    }
  }

  async function leaveGroup(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot leave groups.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupMember(group)) {
      setStatus("Group not found or you are not a member.");
      return;
    }
    if (isGroupOwner(group)) {
      setStatus("Group owners cannot leave their own group. Delete or transfer ownership first.");
      return;
    }
    try {
      await state.db.ref(groupPath + "/" + group.id + "/members/" + state.deviceId).remove();
      if (state.activeGroupId === group.id) {
        state.activeGroupId = getDefaultGroupId() || "";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Left group " + group.name + ".");
    } catch (error) {
      console.error("Arcady leave group failed:", error);
      setStatus("Could not leave the group right now.");
    }
  }

  async function manageGroup(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot manage groups.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupOwner(group)) {
      setStatus("You are not the owner of that group.");
      return;
    }
    const memberKeys = Object.keys(group.members || {}).filter(function (key) { return !!group.members[key]; });
    const inviteKeys = Object.keys(group.invites || {}).filter(function (key) { return !!group.invites[key]; });

    const promptValue = prompt(
      "Manage group: " + group.name + "\n\nMembers:\n" + memberKeys.join(", ") + "\n\nInvites:\n" + inviteKeys.join(", ") + "\n\nEnter nicknames to invite separated by commas, or prefix with '-' to remove a membership/invite.",
      ""
    );
    if (promptValue == null) {
      return;
    }
    const updates = {};
    String(promptValue || "").split(",").map(function (value) {
      return String(value || "").trim();
    }).filter(Boolean).forEach(function (entry) {
      if (entry.startsWith("-")) {
        const key = normalizeNicknameKey(entry.slice(1));
        if (key) {
          updates["members/" + key] = null;
          updates["invites/" + key] = null;
        }
      } else {
        const key = normalizeNicknameKey(entry);
        if (key && key !== getNicknameKey()) {
          updates["invites/" + key] = true;
        }
      }
    });

    if (!Object.keys(updates).length) {
      setStatus("No changes made to the group.");
      return;
    }

    try {
      await state.db.ref(groupPath + "/" + group.id).update(updates);
      renderGroupMenu();
      updateGroupSelectOptions();
      setStatus("Group " + group.name + " updated.");
    } catch (error) {
      console.error("Arcady manage group failed:", error);
      setStatus("Could not update the group.");
    }
  }

  function resolveDeviceIdForNicknameKey(nicknameKey) {
    const key = normalizeNicknameKey(nicknameKey);
    if (!key) {
      return "";
    }
    for (let i = 0; i < state.messages.length; i += 1) {
      const message = state.messages[i];
      if (normalizeNicknameKey(message.nicknameKey || message.nickname) === key && message.deviceId) {
        return message.deviceId;
      }
      if (normalizeNicknameKey(message.recipientNicknameKey || message.recipientNickname) === key && message.recipientDeviceId) {
        return message.recipientDeviceId;
      }
    }
    return "";
  }

  function renderMessages(shouldScroll) {
    if (!els.feed) {
      return;
    }

    const stickToBottom = shouldScroll || isNearBottom(els.feed);
    let visibleMessages = state.messages.filter(function (message) {
      if (state.activeChannel === "dm") {
        return isDirectMessage(message) && isDirectMessageVisibleToCurrentUser(message);
      }
      if (state.activeChannel === "group") {
        return isGroupMessage(message) && message.groupId && message.groupId === state.activeGroupId;
      }
      return !message.type || message.type === "general";
    });

    if (state.activeChannel === "group" && !state.activeGroupId) {
      els.feed.innerHTML = '<div class="home-chat-empty">Select or create a group first using the group menu.</div>';
      return;
    }

    if (!visibleMessages.length) {
      const emptyText = state.activeChannel === "dm"
        ? "No direct messages yet. Choose a recipient and send one."
        : state.activeChannel === "group"
        ? "No messages yet in this group. Send the first one."
        : "No messages yet. Save a nickname above and be the first one to say something.";
      els.feed.innerHTML = '<div class="home-chat-empty" id="home-chat-empty">' + escapeHtml(emptyText) + '</div>';
      return;
    }

    els.feed.innerHTML = visibleMessages.map(function (message) {
      const banned = isMessageChatBanned(message);
      const timedOut = isMessageChatTimedOut(message);
      const protectedMessage = isProtectedNickname(message.nickname) || isProtectedNickname(message.nicknameKey);
      const shownNickname = displayNickname(message.nickname);
      const profileKey = getProfileKey(message);
      const profileCard = state.selectedProfileKey && state.selectedProfileKey === profileKey
        ? renderProfileCard(message)
        : "";
      const ownerActions = canModerateChatLikeOwner() ? (
        '<div class="home-chat-message-actions">' +
          '<button class="home-chat-action-button" type="button" data-chat-edit="' + escapeAttribute(message.id) + '">Edit</button>' +
          '<button class="home-chat-action-button is-danger" type="button" data-chat-delete="' + escapeAttribute(message.id) + '">Delete</button>' +
          '<button class="home-chat-action-button is-danger" type="button" data-chat-ban="' + escapeAttribute(message.id) + '"' + (protectedMessage ? ' disabled' : '') + '>' + (protectedMessage ? 'Arcady Protected' : (banned ? 'Unban' : 'Ban')) + '</button>' +
        '</div>'
      ) : "";
      const stickerDisp = message.stickerDisplay || "box";
      const hasMedia = !!(message.imageDataUrl);
      const inlineMedia = hasMedia && stickerDisp === "inline";
      const boxMedia = hasMedia && !inlineMedia;
      let bodyHtml = "";
      if (message.text || inlineMedia) {
        const textPart = message.text ? formatMessageTextRich(message.text) : "";
        const inlineImg = inlineMedia
          ? '<img class="home-chat-message-sticker-inline" src="' +
            escapeAttribute(message.imageDataUrl) +
            '" width="32" height="32" alt="" loading="lazy" decoding="async">'
          : "";
        bodyHtml =
          '<div class="home-chat-message-text' +
          (inlineMedia ? " home-chat-message-text--with-inline" : "") +
          '">' +
          inlineImg +
          textPart +
          "</div>";
      }
      const boxImg = boxMedia
        ? '<img class="home-chat-message-image" src="' +
          escapeAttribute(message.imageDataUrl) +
          '" alt="Chat image from ' +
          escapeAttribute(shownNickname) +
          '" loading="lazy">'
        : "";
      return (
        '<article class="home-chat-message" data-message-id="' + escapeAttribute(message.id) + '">' +
          '<div class="home-chat-message-head">' +
            renderMessageAvatar(message) +
            '<div class="home-chat-message-head-main">' +
              '<div class="home-chat-message-head-top">' +
                '<div class="home-chat-message-name-row">' +
                  renderStyledNicknameButton(message, shownNickname) +
                  renderMessageNameTags(message) +
                  renderMessageBadges(message, banned, timedOut) +
                  '<button class="home-chat-msg-action" type="button" data-chat-reply="' + escapeAttribute(message.id) + '">Reply</button>' +
                "</div>" +
                '<div class="home-chat-message-time">' + escapeHtml(formatMessageTime(message)) + "</div>" +
              "</div>" +
            "</div>" +
          "</div>" +
          renderReplyQuoteBlock(message) +
          bodyHtml +
          boxImg +
          renderReactionBar(message) +
          profileCard +
          ownerActions +
        '</article>'
      );
    }).join("");

    if (stickToBottom) {
      els.feed.scrollTop = els.feed.scrollHeight;
    }
  }

  function isGroupMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "group" && message.groupId);
  }

  function isDirectMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "dm" && (message.recipientNicknameKey || message.recipientNickname));
  }

  function normalizeMessage(record, id) {
    return {
      id: String(record && record.id || id || ""),
      nickname: String(record && record.nickname || "Guest").trim() || "Guest",
      nicknameKey: normalizeNicknameKey(record && record.nicknameKey || record && record.nickname || ""),
      deviceId: String(record && record.deviceId || "").trim(),
      recipientNickname: String(record && record.recipientNickname || "").trim(),
      recipientNicknameKey: normalizeNicknameKey(record && record.recipientNicknameKey || record && record.recipientNickname || ""),
      recipientDeviceId: String(record && record.recipientDeviceId || "").trim(),
      avatarUrl: sanitizeAvatarUrl(record && record.avatarUrl),
      text: String(record && record.text || "").trim(),
      imageDataUrl: String(record && record.imageDataUrl || "").trim(),
      stickerDisplay: normalizeStickerDisplay(record && record.stickerDisplay),
      reactions: normalizeReactions(record && record.reactions),
      createdAt: Number(record && record.createdAt || 0),
      editedAt: Number(record && record.editedAt || 0),
      replyToId: String(record && record.replyToId || "").trim(),
      replyToNickname: String(record && record.replyToNickname || "").trim(),
      replyToSnippet: String(record && record.replyToSnippet || "").trim().slice(0, 200),
      replyToHasImage: !!(record && record.replyToHasImage),
      nickStyle: normalizeNickStyleForMessage(record && record.nickStyle),
      type: String(record && record.type || "general").trim().toLowerCase(),
      groupId: String(record && record.groupId || "").trim()
    };
  }

  function sendMessage() {
    const nickname = readNickname();
    if (!nickname) {
      setStatus("Save a nickname above first.");
      updateComposerState();
      return;
    }

    if (isCurrentUserChatBanned()) {
      setStatus("You are banned from the chat.");
      updateComposerState();
      return;
    }

    if (isCurrentUserChatTimedOut()) {
      setStatus("You are timed out from chat.");
      updateComposerState();
      return;
    }

    if (!state.ready || !state.db || state.sending) {
      return;
    }

    const text = String(els.input.value || "").trim().slice(0, 400);
    if (!text && !state.selectedImage && !state.selectedGifUrl) {
      setStatus("Write a message or add an image.");
      updateComposerState();
      return;
    }

    state.sending = true;
    updateComposerState();
    setStatus("Sending message...");

    (async function () {
      try {
        let imageDataUrl = "";
        if (state.selectedGifUrl) {
          imageDataUrl = state.selectedGifUrl;
        } else if (state.selectedImage) {
          imageDataUrl = await readFileAsDataUrl(state.selectedImage);
        }

        const avatarUrl = readAvatarForSend();
        const ref = state.db.ref(chatPath).push();
        const payload = {
          id: ref.key,
          deviceId: state.deviceId,
          nickname: nickname,
          nicknameKey: getNicknameKey(),
          recipientNickname: "",
          recipientNicknameKey: "",
          recipientDeviceId: "",
          avatarUrl: avatarUrl,
          text: text,
          imageDataUrl: imageDataUrl,
          createdAt: Date.now(),
          type: state.activeChannel === "group" ? "group" : state.activeChannel === "dm" ? "dm" : "general",
          groupId: state.activeChannel === "group" ? state.activeGroupId : ""
        };
        const ns = getNickStyleForPayload();
        if (ns) {
          payload.nickStyle = ns;
        }
        if (imageDataUrl) {
          payload.stickerDisplay = state.stickerSendMode === "inline" ? "inline" : "box";
        }
        if (state.activeChannel === "dm" && state.dmTargetNickname) {
          payload.recipientNickname = state.dmTargetNickname;
          payload.recipientNicknameKey = state.dmTargetNicknameKey || normalizeNicknameKey(state.dmTargetNickname);
          const foundDevice = resolveDeviceIdForNicknameKey(payload.recipientNicknameKey);
          if (foundDevice) {
            payload.recipientDeviceId = foundDevice;
          }
        }
        const reply = state.replyDraft;
        if (reply && reply.id) {
          payload.replyToId = reply.id;
          payload.replyToNickname = reply.nickname;
          payload.replyToSnippet = reply.snippet;
          payload.replyToHasImage = !!reply.hasImage;
        }
        await ref.set(payload);

        els.input.value = "";
        hideMentionSuggest();
        hideEmojiSuggest();
        clearReplyDraft();
        await clearTypingPresence();
        clearSelectedImage();
        clearSelectedGif();
        state.gifPanelOpen = false;
        syncGifPickerUi();
        setStatus("Chat live. Say something.");
        if (els.input && !els.input.disabled) {
          els.input.focus();
        }
      } catch (error) {
        console.error("Arcady homepage chat send failed:", error);
        setStatus("That message could not send.");
      } finally {
        state.sending = false;
        updateComposerState();
      }
    })();
  }

  function subscribeToGroups() {
    if (!state.db) {
      return;
    }
    state.db.ref(groupPath).on("value", function (snapshot) {
      state.groups = snapshot.val() || {};
      updateGroupSelectOptions();
      renderGroupMenu();
      renderChannelInfo();
      renderMessages(false);
    });
  }

  function isGroupMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "group" && message.groupId);
  }

  function isDirectMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "dm" && (message.recipientNicknameKey || message.recipientNickname));
  }

  function normalizeMessage(record, id) {
    return {
      id: String(record && record.id || id || ""),
      nickname: String(record && record.nickname || "Guest").trim() || "Guest",
      nicknameKey: normalizeNicknameKey(record && record.nicknameKey || record && record.nickname || ""),
      deviceId: String(record && record.deviceId || "").trim(),
      recipientNickname: String(record && record.recipientNickname || "").trim(),
      recipientNicknameKey: normalizeNicknameKey(record && record.recipientNicknameKey || record && record.recipientNickname || ""),
      recipientDeviceId: String(record && record.recipientDeviceId || "").trim(),
      avatarUrl: sanitizeAvatarUrl(record && record.avatarUrl),
      text: String(record && record.text || "").trim(),
      imageDataUrl: String(record && record.imageDataUrl || "").trim(),
      stickerDisplay: normalizeStickerDisplay(record && record.stickerDisplay),
      reactions: normalizeReactions(record && record.reactions),
      createdAt: Number(record && record.createdAt || 0),
      editedAt: Number(record && record.editedAt || 0),
      replyToId: String(record && record.replyToId || "").trim(),
      replyToNickname: String(record && record.replyToNickname || "").trim(),
      replyToSnippet: String(record && record.replyToSnippet || "").trim().slice(0, 200),
      replyToHasImage: !!(record && record.replyToHasImage),
      nickStyle: normalizeNickStyleForMessage(record && record.nickStyle),
      type: String(record && record.type || "general").trim().toLowerCase(),
      groupId: String(record && record.groupId || "").trim()
    };
  }

  function renderMessages(shouldScroll) {
    if (!els.feed) {
      return;
    }

    const stickToBottom = shouldScroll || isNearBottom(els.feed);
    let visibleMessages = state.messages.filter(function (message) {
      if (state.activeChannel === "dm") {
        return isDirectMessage(message) && isDirectMessageVisibleToCurrentUser(message);
      }
      if (state.activeChannel === "group") {
        return isGroupMessage(message) && message.groupId && message.groupId === state.activeGroupId;
      }
      return !message.type || message.type === "general";
    });

    if (state.activeChannel === "group" && !state.activeGroupId) {
      els.feed.innerHTML = '<div class="home-chat-empty">Select or create a group first using the group menu.</div>';
      return;
    }

    if (!visibleMessages.length) {
      const emptyText = state.activeChannel === "dm"
        ? "No direct messages yet. Choose a recipient and send one."
        : state.activeChannel === "group"
        ? "No messages yet in this group. Send the first one."
        : "No messages yet. Save a nickname above and be the first one to say something.";
      els.feed.innerHTML = '<div class="home-chat-empty" id="home-chat-empty">' + escapeHtml(emptyText) + '</div>';
      return;
    }

    els.feed.innerHTML = visibleMessages.map(function (message) {
      const banned = isMessageChatBanned(message);
      const timedOut = isMessageChatTimedOut(message);
      const protectedMessage = isProtectedNickname(message.nickname) || isProtectedNickname(message.nicknameKey);
      const shownNickname = displayNickname(message.nickname);
      const profileKey = getProfileKey(message);
      const profileCard = state.selectedProfileKey && state.selectedProfileKey === profileKey
        ? renderProfileCard(message)
        : "";
      const ownerActions = canModerateChatLikeOwner() ? (
        '<div class="home-chat-message-actions">' +
          '<button class="home-chat-action-button" type="button" data-chat-edit="' + escapeAttribute(message.id) + '">Edit</button>' +
          '<button class="home-chat-action-button is-danger" type="button" data-chat-delete="' + escapeAttribute(message.id) + '">Delete</button>' +
          '<button class="home-chat-action-button is-danger" type="button" data-chat-ban="' + escapeAttribute(message.id) + '"' + (protectedMessage ? ' disabled' : '') + '>' + (protectedMessage ? 'Arcady Protected' : (banned ? 'Unban' : 'Ban')) + '</button>' +
        '</div>'
      ) : "";
      const stickerDisp = message.stickerDisplay || "box";
      const hasMedia = !!(message.imageDataUrl);
      const inlineMedia = hasMedia && stickerDisp === "inline";
      const boxMedia = hasMedia && !inlineMedia;
      let bodyHtml = "";
      if (message.text || inlineMedia) {
        const textPart = message.text ? formatMessageTextRich(message.text) : "";
        const inlineImg = inlineMedia
          ? '<img class="home-chat-message-sticker-inline" src="' +
            escapeAttribute(message.imageDataUrl) +
            '" width="32" height="32" alt="" loading="lazy" decoding="async">'
          : "";
        bodyHtml =
          '<div class="home-chat-message-text' +
          (inlineMedia ? " home-chat-message-text--with-inline" : "") +
          '">' +
          inlineImg +
          textPart +
          "</div>";
      }
      const boxImg = boxMedia
        ? '<img class="home-chat-message-image" src="' +
          escapeAttribute(message.imageDataUrl) +
          '" alt="Chat image from ' +
          escapeAttribute(shownNickname) +
          '" loading="lazy">'
        : "";
      return (
        '<article class="home-chat-message" data-message-id="' + escapeAttribute(message.id) + '">' +
          '<div class="home-chat-message-head">' +
            renderMessageAvatar(message) +
            '<div class="home-chat-message-head-main">' +
              '<div class="home-chat-message-head-top">' +
                '<div class="home-chat-message-name-row">' +
                  renderStyledNicknameButton(message, shownNickname) +
                  renderMessageNameTags(message) +
                  renderMessageBadges(message, banned, timedOut) +
                  '<button class="home-chat-msg-action" type="button" data-chat-reply="' + escapeAttribute(message.id) + '">Reply</button>' +
                "</div>" +
                '<div class="home-chat-message-time">' + escapeHtml(formatMessageTime(message)) + "</div>" +
              "</div>" +
            "</div>" +
          "</div>" +
          renderReplyQuoteBlock(message) +
          bodyHtml +
          boxImg +
          renderReactionBar(message) +
          profileCard +
          ownerActions +
        '</article>'
      );
    }).join("");

    if (stickToBottom) {
      els.feed.scrollTop = els.feed.scrollHeight;
    }
  }

  function isGroupMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "group" && message.groupId);
  }

  function isDirectMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "dm" && (message.recipientNicknameKey || message.recipientNickname));
  }

  function normalizeMessage(record, id) {
    return {
      id: String(record && record.id || id || ""),
      nickname: String(record && record.nickname || "Guest").trim() || "Guest",
      nicknameKey: normalizeNicknameKey(record && record.nicknameKey || record && record.nickname || ""),
      deviceId: String(record && record.deviceId || "").trim(),
      recipientNickname: String(record && record.recipientNickname || "").trim(),
      recipientNicknameKey: normalizeNicknameKey(record && record.recipientNicknameKey || record && record.recipientNickname || ""),
      recipientDeviceId: String(record && record.recipientDeviceId || "").trim(),
      avatarUrl: sanitizeAvatarUrl(record && record.avatarUrl),
      text: String(record && record.text || "").trim(),
      imageDataUrl: String(record && record.imageDataUrl || "").trim(),
      stickerDisplay: normalizeStickerDisplay(record && record.stickerDisplay),
      reactions: normalizeReactions(record && record.reactions),
      createdAt: Number(record && record.createdAt || 0),
      editedAt: Number(record && record.editedAt || 0),
      replyToId: String(record && record.replyToId || "").trim(),
      replyToNickname: String(record && record.replyToNickname || "").trim(),
      replyToSnippet: String(record && record.replyToSnippet || "").trim().slice(0, 200),
      replyToHasImage: !!(record && record.replyToHasImage),
      nickStyle: normalizeNickStyleForMessage(record && record.nickStyle),
      type: String(record && record.type || "general").trim().toLowerCase(),
      groupId: String(record && record.groupId || "").trim()
    };
  }

  function sendMessage() {
    const nickname = readNickname();
    if (!nickname) {
      setStatus("Save a nickname above first.");
      updateComposerState();
      return;
    }

    if (isCurrentUserChatBanned()) {
      setStatus("You are banned from the chat.");
      updateComposerState();
      return;
    }

    if (isCurrentUserChatTimedOut()) {
      setStatus("You are timed out from chat.");
      updateComposerState();
      return;
    }

    if (!state.ready || !state.db || state.sending) {
      return;
    }

    const text = String(els.input.value || "").trim().slice(0, 400);
    if (!text && !state.selectedImage && !state.selectedGifUrl) {
      setStatus("Write a message or add an image.");
      updateComposerState();
      return;
    }

    state.sending = true;
    updateComposerState();
    setStatus("Sending message...");

    (async function () {
      try {
        let imageDataUrl = "";
        if (state.selectedGifUrl) {
          imageDataUrl = state.selectedGifUrl;
        } else if (state.selectedImage) {
          imageDataUrl = await readFileAsDataUrl(state.selectedImage);
        }

        const avatarUrl = readAvatarForSend();
        const ref = state.db.ref(chatPath).push();
        const payload = {
          id: ref.key,
          deviceId: state.deviceId,
          nickname: nickname,
          nicknameKey: getNicknameKey(),
          recipientNickname: "",
          recipientNicknameKey: "",
          recipientDeviceId: "",
          avatarUrl: avatarUrl,
          text: text,
          imageDataUrl: imageDataUrl,
          createdAt: Date.now(),
          type: state.activeChannel === "group" ? "group" : state.activeChannel === "dm" ? "dm" : "general",
          groupId: state.activeChannel === "group" ? state.activeGroupId : ""
        };
        const ns = getNickStyleForPayload();
        if (ns) {
          payload.nickStyle = ns;
        }
        if (imageDataUrl) {
          payload.stickerDisplay = state.stickerSendMode === "inline" ? "inline" : "box";
        }
        if (state.activeChannel === "dm" && state.dmTargetNickname) {
          payload.recipientNickname = state.dmTargetNickname;
          payload.recipientNicknameKey = state.dmTargetNicknameKey || normalizeNicknameKey(state.dmTargetNickname);
          const foundDevice = resolveDeviceIdForNicknameKey(payload.recipientNicknameKey);
          if (foundDevice) {
            payload.recipientDeviceId = foundDevice;
          }
        }
        const reply = state.replyDraft;
        if (reply && reply.id) {
          payload.replyToId = reply.id;
          payload.replyToNickname = reply.nickname;
          payload.replyToSnippet = reply.snippet;
          payload.replyToHasImage = !!reply.hasImage;
        }
        await ref.set(payload);

        els.input.value = "";
        hideMentionSuggest();
        hideEmojiSuggest();
        clearReplyDraft();
        await clearTypingPresence();
        clearSelectedImage();
        clearSelectedGif();
        state.gifPanelOpen = false;
        syncGifPickerUi();
        setStatus("Chat live. Say something.");
        if (els.input && !els.input.disabled) {
          els.input.focus();
        }
      } catch (error) {
        console.error("Arcady homepage chat send failed:", error);
        setStatus("That message could not send.");
      } finally {
        state.sending = false;
        updateComposerState();
      }
    })();
  }

  function subscribeToGroups() {
    if (!state.db) {
      return;
    }
    state.db.ref(groupPath).on("value", function (snapshot) {
      state.groups = snapshot.val() || {};
      updateGroupSelectOptions();
      renderGroupMenu();
      renderChannelInfo();
      renderMessages(false);
    });
  }

  function isGroupMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "group" && message.groupId);
  }

  function isDirectMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "dm" && (message.recipientNicknameKey || message.recipientNickname));
  }

  function normalizeMessage(record, id) {
    return {
      id: String(record && record.id || id || ""),
      nickname: String(record && record.nickname || "Guest").trim() || "Guest",
      nicknameKey: normalizeNicknameKey(record && record.nicknameKey || record && record.nickname || ""),
      deviceId: String(record && record.deviceId || "").trim(),
      recipientNickname: String(record && record.recipientNickname || "").trim(),
      recipientNicknameKey: normalizeNicknameKey(record && record.recipientNicknameKey || record && record.recipientNickname || ""),
      recipientDeviceId: String(record && record.recipientDeviceId || "").trim(),
      avatarUrl: sanitizeAvatarUrl(record && record.avatarUrl),
      text: String(record && record.text || "").trim(),
      imageDataUrl: String(record && record.imageDataUrl || "").trim(),
      stickerDisplay: normalizeStickerDisplay(record && record.stickerDisplay),
      reactions: normalizeReactions(record && record.reactions),
      createdAt: Number(record && record.createdAt || 0),
      editedAt: Number(record && record.editedAt || 0),
      replyToId: String(record && record.replyToId || "").trim(),
      replyToNickname: String(record && record.replyToNickname || "").trim(),
      replyToSnippet: String(record && record.replyToSnippet || "").trim().slice(0, 200),
      replyToHasImage: !!(record && record.replyToHasImage),
      nickStyle: normalizeNickStyleForMessage(record && record.nickStyle),
      type: String(record && record.type || "general").trim().toLowerCase(),
      groupId: String(record && record.groupId || "").trim()
    };
  }

  function sendMessage() {
    const nickname = readNickname();
    if (!nickname) {
      setStatus("Save a nickname above first.");
      updateComposerState();
      return;
    }

    if (isCurrentUserChatBanned()) {
      setStatus("You are banned from the chat.");
      updateComposerState();
      return;
    }

    if (isCurrentUserChatTimedOut()) {
      setStatus("You are timed out from chat.");
      updateComposerState();
      return;
    }

    if (!state.ready || !state.db || state.sending) {
      return;
    }

    const text = String(els.input.value || "").trim().slice(0, 400);
    if (!text && !state.selectedImage && !state.selectedGifUrl) {
      setStatus("Write a message or add an image.");
      updateComposerState();
      return;
    }

    state.sending = true;
    updateComposerState();
    setStatus("Sending message...");

    (async function () {
      try {
        let imageDataUrl = "";
        if (state.selectedGifUrl) {
          imageDataUrl = state.selectedGifUrl;
        } else if (state.selectedImage) {
          imageDataUrl = await readFileAsDataUrl(state.selectedImage);
        }

        const avatarUrl = readAvatarForSend();
        const ref = state.db.ref(chatPath).push();
        const payload = {
          id: ref.key,
          deviceId: state.deviceId,
          nickname: nickname,
          nicknameKey: getNicknameKey(),
          recipientNickname: "",
          recipientNicknameKey: "",
          recipientDeviceId: "",
          avatarUrl: avatarUrl,
          text: text,
          imageDataUrl: imageDataUrl,
          createdAt: Date.now(),
          type: state.activeChannel === "group" ? "group" : state.activeChannel === "dm" ? "dm" : "general",
          groupId: state.activeChannel === "group" ? state.activeGroupId : ""
        };
        const ns = getNickStyleForPayload();
        if (ns) {
          payload.nickStyle = ns;
        }
        if (imageDataUrl) {
          payload.stickerDisplay = state.stickerSendMode === "inline" ? "inline" : "box";
        }
        if (state.activeChannel === "dm" && state.dmTargetNickname) {
          payload.recipientNickname = state.dmTargetNickname;
          payload.recipientNicknameKey = state.dmTargetNicknameKey || normalizeNicknameKey(state.dmTargetNickname);
          const foundDevice = resolveDeviceIdForNicknameKey(payload.recipientNicknameKey);
          if (foundDevice) {
            payload.recipientDeviceId = foundDevice;
          }
        }
        const reply = state.replyDraft;
        if (reply && reply.id) {
          payload.replyToId = reply.id;
          payload.replyToNickname = reply.nickname;
          payload.replyToSnippet = reply.snippet;
          payload.replyToHasImage = !!reply.hasImage;
        }
        await ref.set(payload);

        els.input.value = "";
        hideMentionSuggest();
        hideEmojiSuggest();
        clearReplyDraft();
        await clearTypingPresence();
        clearSelectedImage();
        clearSelectedGif();
        state.gifPanelOpen = false;
        syncGifPickerUi();
        setStatus("Chat live. Say something.");
        if (els.input && !els.input.disabled) {
          els.input.focus();
        }
      } catch (error) {
        console.error("Arcady homepage chat send failed:", error);
        setStatus("That message could not send.");
      } finally {
        state.sending = false;
        updateComposerState();
      }
    })();
  }

  function subscribeToGroups() {
    if (!state.db) {
      return;
    }
    state.db.ref(groupPath).on("value", function (snapshot) {
      state.groups = snapshot.val() || {};
      updateGroupSelectOptions();
      renderGroupMenu();
      renderChannelInfo();
      renderMessages(false);
    });
  }

  function isGroupMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "group" && message.groupId);
  }

  function isDirectMessage(message) {
    return !!(message && String(message.type || "").toLowerCase() === "dm" && (message.recipientNicknameKey || message.recipientNickname));
  }

  function normalizeMessage(record, id) {
    return {
      id: String(record && record.id || id || ""),
      nickname: String(record && record.nickname || "Guest").trim() || "Guest",
      nicknameKey: normalizeNicknameKey(record && record.nicknameKey || record && record.nickname || ""),
      deviceId: String(record && record.deviceId || "").trim(),
      recipientNickname: String(record && record.recipientNickname || "").trim(),
      recipientNicknameKey: normalizeNicknameKey(record && record.recipientNicknameKey || record && record.recipientNickname || ""),
      recipientDeviceId: String(record && record.recipientDeviceId || "").trim(),
      avatarUrl: sanitizeAvatarUrl(record && record.avatarUrl),
      text: String(record && record.text || "").trim(),
      imageDataUrl: String(record && record.imageDataUrl || "").trim(),
      stickerDisplay: normalizeStickerDisplay(record && record.stickerDisplay),
      reactions: normalizeReactions(record && record.reactions),
      createdAt: Number(record && record.createdAt || 0),
      editedAt: Number(record && record.editedAt || 0),
      replyToId: String(record && record.replyToId || "").trim(),
      replyToNickname: String(record && record.replyToNickname || "").trim(),
      replyToSnippet: String(record && record.replyToSnippet || "").trim().slice(0, 200),
      replyToHasImage: !!(record && record.replyToHasImage),
      nickStyle: normalizeNickStyleForMessage(record && record.nickStyle),
      type: String(record && record.type || "general").trim().toLowerCase(),
      groupId: String(record && record.groupId || "").trim()
    };
  }

  function renderChannelInfo() {
    if (!els.channelInfo) {
      return;
    }
    if (state.activeChannel === "dm") {
      if (state.dmTargetNickname) {
        els.channelInfo.textContent = "Direct messages to " + state.dmTargetNickname + ". Only you and the recipient can see these if the recipient is a matching nickname.";
      } else {
        els.channelInfo.textContent = "Direct Message mode: type a nickname to send a private message.";
      }
      return;
    }
    if (state.activeChannel === "group") {
      const group = state.activeGroupId ? normalizeGroupRecord(state.activeGroupId, state.groups[state.activeGroupId]) : null;
      if (group && isGroupMember(group)) {
        els.channelInfo.textContent = "Group chat: " + group.name + ". Messages are visible only inside this group.";
      } else if (group && isGroupInvite(group)) {
        els.channelInfo.textContent = "You have an invite for " + group.name + ". Accept it from the group menu.";
      } else {
        els.channelInfo.textContent = "Group chat mode: select a group or create one to begin.";
      }
      return;
    }
    els.channelInfo.textContent = "Public chat: all users can see messages here.";
  }

  function updateGroupSelectOptions() {
    if (!els.groupSelect) {
      return;
    }

    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });

    if (!groups.length) {
      els.groupSelect.innerHTML = '<option value="">No groups available</option>';
      els.groupSelect.disabled = true;
      return;
    }

    const html = [
      '<option value="">Choose a group...</option>'
    ].concat(groups.map(function (group) {
      return '<option value="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + '</option>';
    }));
    els.groupSelect.innerHTML = html.join("");
    els.groupSelect.disabled = false;
    if (state.activeGroupId && groups.some(function (group) { return group.id === state.activeGroupId; })) {
      els.groupSelect.value = state.activeGroupId;
    } else {
      state.activeGroupId = groups.length ? groups[0].id : "";
      els.groupSelect.value = state.activeGroupId;
    }
  }

  async function createGroup() {
    const nickname = readNickname();
    if (!nickname) {
      setStatus("Save a nickname above first.");
      return;
    }
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot create a group right now.");
      return;
    }

    const groupName = String(prompt("Group name:", "My Group") || "").trim().slice(0, 40);
    if (!groupName) {
      return;
    }

    const inviteNames = String(prompt("Optional invite nicknames, comma-separated:", "") || "").trim();
    const groupRef = state.db.ref(groupPath).push();
    if (!groupRef || !groupRef.key) {
      setStatus("Unable to create group at the moment.");
      return;
    }

    const groupId = groupRef.key;
    const payload = {
      id: groupId,
      name: groupName,
      ownerDeviceId: state.deviceId,
      ownerNickname: nickname,
      createdAt: Date.now(),
      members: {},
      invites: {}
    };
    payload.members[state.deviceId] = true;

    if (inviteNames) {
      inviteNames.split(",").map(function (value) {
        return String(value || "").trim().slice(0, 24);
      }).filter(Boolean).forEach(function (invite) {
        const key = normalizeNicknameKey(invite);
        if (key && key !== getNicknameKey()) {
          payload.invites[key] = true;
        }
      });
    }

    try {
      await groupRef.set(payload);
      state.activeChannel = "group";
      state.activeGroupId = groupId;
      if (els.channelSelect) {
        els.channelSelect.value = "group";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Group created: " + groupName + ". Use the group menu to manage it.");
    } catch (error) {
      console.error("Arcady create group failed:", error);
      setStatus("Could not create group right now.");
    }
  }

  async function acceptGroupInvite(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot accept invites.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupInvite(group)) {
      setStatus("Invite not found.");
      return;
    }
    const selfKey = getNicknameKey();
    const update = {};
    update["members/" + state.deviceId] = true;
    update["invites/" + selfKey] = null;
    try {
      await state.db.ref(groupPath + "/" + group.id).update(update);
      state.activeChannel = "group";
      state.activeGroupId = group.id;
      if (els.channelSelect) {
        els.channelSelect.value = "group";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Joined group " + group.name + ".");
    } catch (error) {
      console.error("Arcady accept group invite failed:", error);
      setStatus("Could not join the group.");
    }
  }

  async function leaveGroup(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot leave groups.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupMember(group)) {
      setStatus("Group not found or you are not a member.");
      return;
    }
    if (isGroupOwner(group)) {
      setStatus("Group owners cannot leave their own group. Delete or transfer ownership first.");
      return;
    }
    try {
      await state.db.ref(groupPath + "/" + group.id + "/members/" + state.deviceId).remove();
      if (state.activeGroupId === group.id) {
        state.activeGroupId = getDefaultGroupId() || "";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Left group " + group.name + ".");
    } catch (error) {
      console.error("Arcady leave group failed:", error);
      setStatus("Could not leave the group right now.");
    }
  }

  async function manageGroup(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot manage groups.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupOwner(group)) {
      setStatus("You are not the owner of that group.");
      return;
    }
    const memberKeys = Object.keys(group.members || {}).filter(function (key) { return !!group.members[key]; });
    const inviteKeys = Object.keys(group.invites || {}).filter(function (key) { return !!group.invites[key]; });

    const promptValue = prompt(
      "Manage group: " + group.name + "\n\nMembers:\n" + memberKeys.join(", ") + "\n\nInvites:\n" + inviteKeys.join(", ") + "\n\nEnter nicknames to invite separated by commas, or prefix with '-' to remove a membership/invite.",
      ""
    );
    if (promptValue == null) {
      return;
    }
    const updates = {};
    String(promptValue || "").split(",").map(function (value) {
      return String(value || "").trim();
    }).filter(Boolean).forEach(function (entry) {
      if (entry.startsWith("-")) {
        const key = normalizeNicknameKey(entry.slice(1));
        if (key) {
          updates["members/" + key] = null;
          updates["invites/" + key] = null;
        }
      } else {
        const key = normalizeNicknameKey(entry);
        if (key && key !== getNicknameKey()) {
          updates["invites/" + key] = true;
        }
      }
    });

    if (!Object.keys(updates).length) {
      setStatus("No changes made to the group.");
      return;
    }

    try {
      await state.db.ref(groupPath + "/" + group.id).update(updates);
      renderGroupMenu();
      updateGroupSelectOptions();
      setStatus("Group " + group.name + " updated.");
    } catch (error) {
      console.error("Arcady manage group failed:", error);
      setStatus("Could not update the group.");
    }
  }

  function resolveDeviceIdForNicknameKey(nicknameKey) {
    const key = normalizeNicknameKey(nicknameKey);
    if (!key) {
      return "";
    }
    for (let i = 0; i < state.messages.length; i += 1) {
      const message = state.messages[i];
      if (normalizeNicknameKey(message.nicknameKey || message.nickname) === key && message.deviceId) {
        return message.deviceId;
      }
      if (normalizeNicknameKey(message.recipientNicknameKey || message.recipientNickname) === key && message.recipientDeviceId) {
        return message.recipientDeviceId;
      }
    }
    return "";
  }

  function isDirectMessageVisibleToCurrentUser(message) {
    if (!message) {
      return false;
    }
    if (canModerateChatLikeOwner()) {
      return true;
    }
    const selfKey = getNicknameKey();
    if (!selfKey) {
      return false;
    }
    const senderKey = normalizeNicknameKey(message.nicknameKey || message.nickname);
    if (senderKey === selfKey || message.deviceId === state.deviceId) {
      return true;
    }
    const recipientKey = normalizeNicknameKey(message.recipientNicknameKey || message.recipientNickname);
    if (recipientKey === selfKey || message.recipientDeviceId === state.deviceId) {
      return true;
    }
    return false;
  }

  function getCurrentUserGroups() {
    const selfKey = getNicknameKey();
    return Object.keys(state.groups || {}).map(function (id) {
      return normalizeGroupRecord(id, state.groups[id]);
    }).filter(function (group) {
      return group && (isGroupOwner(group) || isGroupMember(group) || isGroupInvite(group));
    }).sort(function (a, b) {
      return String(a.name || "").localeCompare(String(b.name || ""), undefined, { sensitivity: "base" });
    });
  }

  function isGroupOwner(group) {
    return !!(group && group.ownerDeviceId && group.ownerDeviceId === state.deviceId);
  }

  function isGroupMember(group) {
    return !!(group && group.members && group.members[state.deviceId]);
  }

  function isGroupInvite(group) {
    const selfKey = getNicknameKey();
    return !!(group && group.invites && group.invites[selfKey]);
  }

  function getDefaultGroupId() {
    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });
    return groups.length ? groups[0].id : "";
  }

  function renderChannelInfo() {
    if (!els.channelInfo) {
      return;
    }
    if (state.activeChannel === "dm") {
      if (state.dmTargetNickname) {
        els.channelInfo.textContent = "Direct messages to " + state.dmTargetNickname + ". Only you and the recipient can see these if the recipient matches.";
      } else {
        els.channelInfo.textContent = "Direct Message mode: type a nickname to send a private message.";
      }
      return;
    }
    if (state.activeChannel === "group") {
      const group = state.activeGroupId ? normalizeGroupRecord(state.activeGroupId, state.groups[state.activeGroupId]) : null;
      if (group && isGroupMember(group)) {
        els.channelInfo.textContent = "Group chat: " + group.name + ". Messages are visible only inside this group.";
      } else if (group && isGroupInvite(group)) {
        els.channelInfo.textContent = "You have an invite for " + group.name + ". Accept it from the group menu.";
      } else {
        els.channelInfo.textContent = "Group chat mode: select a group or create one to begin.";
      }
      return;
    }
    els.channelInfo.textContent = "Public chat: all users can see messages here.";
  }

  function updateGroupSelectOptions() {
    if (!els.groupSelect) {
      return;
    }

    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });

    if (!groups.length) {
      els.groupSelect.innerHTML = '<option value="">No groups available</option>';
      els.groupSelect.disabled = true;
      return;
    }

    const html = [
      '<option value="">Choose a group...</option>'
    ].concat(groups.map(function (group) {
      return '<option value="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + '</option>';
    }));
    els.groupSelect.innerHTML = html.join("");
    els.groupSelect.disabled = false;
    if (state.activeGroupId && groups.some(function (group) { return group.id === state.activeGroupId; })) {
      els.groupSelect.value = state.activeGroupId;
    } else {
      state.activeGroupId = groups.length ? groups[0].id : "";
      els.groupSelect.value = state.activeGroupId;
    }
  }

  function createGroup() {
    if (!readNickname()) {
      setStatus("Save a nickname above first.");
      return;
    }
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot create a group right now.");
      return;
    }
    const groupName = String(prompt("Group name:", "My Group") || "").trim().slice(0, 40);
    if (!groupName) {
      return;
    }
    const inviteNames = String(prompt("Optional invite nicknames, comma-separated:", "") || "").trim();
    const groupRef = state.db.ref(groupPath).push();
    if (!groupRef || !groupRef.key) {
      setStatus("Unable to create group at the moment.");
      return;
    }
    const groupId = groupRef.key;
    const payload = {
      id: groupId,
      name: groupName,
      ownerDeviceId: state.deviceId,
      ownerNickname: readNickname(),
      createdAt: Date.now(),
      members: {},
      invites: {}
    };
    payload.members[state.deviceId] = true;
    if (inviteNames) {
      inviteNames.split(",").map(function (value) {
        return String(value || "").trim().slice(0, 24);
      }).filter(Boolean).forEach(function (invite) {
        const key = normalizeNicknameKey(invite);
        if (key && key !== getNicknameKey()) {
          payload.invites[key] = true;
        }
      });
    }
    state.db.ref(groupPath + "/" + groupId).set(payload).then(function () {
      state.activeChannel = "group";
      state.activeGroupId = groupId;
      if (els.channelSelect) {
        els.channelSelect.value = "group";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Group created: " + groupName + ". Use the group menu to manage it.");
    }).catch(function (error) {
      console.error("Arcady create group failed:", error);
      setStatus("Could not create group right now.");
    });
  }

  function acceptGroupInvite(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot accept invites.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupInvite(group)) {
      setStatus("Invite not found.");
      return;
    }
    const selfKey = getNicknameKey();
    const update = {};
    update["members/" + state.deviceId] = true;
    update["invites/" + selfKey] = null;
    state.db.ref(groupPath + "/" + group.id).update(update).then(function () {
      state.activeChannel = "group";
      state.activeGroupId = group.id;
      if (els.channelSelect) {
        els.channelSelect.value = "group";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Joined group " + group.name + ".");
    }).catch(function (error) {
      console.error("Arcady accept group invite failed:", error);
      setStatus("Could not join the group.");
    });
  }

  function leaveGroup(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot leave groups.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupMember(group)) {
      setStatus("Group not found or you are not a member.");
      return;
    }
    if (isGroupOwner(group)) {
      setStatus("Group owners cannot leave their own group. Delete or transfer ownership first.");
      return;
    }
    state.db.ref(groupPath + "/" + group.id + "/members/" + state.deviceId).remove().then(function () {
      if (state.activeGroupId === group.id) {
        state.activeGroupId = getDefaultGroupId() || "";
      }
      updateGroupSelectOptions();
      renderChannelInfo();
      renderMessages(false);
      setStatus("Left group " + group.name + ".");
    }).catch(function (error) {
      console.error("Arcady leave group failed:", error);
      setStatus("Could not leave the group right now.");
    });
  }

  function manageGroup(groupId) {
    if (!state.ready || !state.db) {
      setStatus("Chat is offline and cannot manage groups.");
      return;
    }
    const group = normalizeGroupRecord(groupId, state.groups[groupId]);
    if (!group || !isGroupOwner(group)) {
      setStatus("You are not the owner of that group.");
      return;
    }
    const memberKeys = Object.keys(group.members || {}).filter(function (key) { return !!group.members[key]; });
    const inviteKeys = Object.keys(group.invites || {}).filter(function (key) { return !!group.invites[key]; });
    const promptValue = prompt(
      "Manage group: " + group.name + "\n\nMembers:\n" + memberKeys.join(", ") + "\n\nInvites:\n" + inviteKeys.join(", ") + "\n\nEnter nicknames to invite separated by commas, or prefix with '-' to remove a membership/invite.",
      ""
    );
    if (promptValue == null) {
      return;
    }
    const updates = {};
    String(promptValue || "").split(",").map(function (value) {
      return String(value || "").trim();
    }).filter(Boolean).forEach(function (entry) {
      if (entry.startsWith("-")) {
        const key = normalizeNicknameKey(entry.slice(1));
        if (key) {
          updates["members/" + key] = null;
          updates["invites/" + key] = null;
        }
      } else {
        const key = normalizeNicknameKey(entry);
        if (key && key !== getNicknameKey()) {
          updates["invites/" + key] = true;
        }
      }
    });
    if (!Object.keys(updates).length) {
      setStatus("No changes made to the group.");
      return;
    }
    state.db.ref(groupPath + "/" + group.id).update(updates).then(function () {
      renderGroupMenu();
      updateGroupSelectOptions();
      setStatus("Group " + group.name + " updated.");
    }).catch(function (error) {
      console.error("Arcady manage group failed:", error);
      setStatus("Could not update the group.");
    });
  }

  function resolveDeviceIdForNicknameKey(nicknameKey) {
    const key = normalizeNicknameKey(nicknameKey);
    if (!key) {
      return "";
    }
    for (let i = 0; i < state.messages.length; i += 1) {
      const message = state.messages[i];
      if (normalizeNicknameKey(message.nicknameKey || message.nickname) === key && message.deviceId) {
        return message.deviceId;
      }
      if (normalizeNicknameKey(message.recipientNicknameKey || message.recipientNickname) === key && message.recipientDeviceId) {
        return message.recipientDeviceId;
      }
    }
    return "";
  }

  function isDirectMessageVisibleToCurrentUser(message) {
    if (!message) {
      return false;
    }
    if (canModerateChatLikeOwner()) {
      return true;
    }
    const selfKey = getNicknameKey();
    if (!selfKey) {
      return false;
    }
    const senderKey = normalizeNicknameKey(message.nicknameKey || message.nickname);
    if (senderKey === selfKey || message.deviceId === state.deviceId) {
      return true;
    }
    const recipientKey = normalizeNicknameKey(message.recipientNicknameKey || message.recipientNickname);
    if (recipientKey === selfKey || message.recipientDeviceId === state.deviceId) {
      return true;
    }
    return false;
  }

  function getCurrentUserGroups() {
    const selfKey = getNicknameKey();
    return Object.keys(state.groups || {}).map(function (id) {
      return normalizeGroupRecord(id, state.groups[id]);
    }).filter(function (group) {
      return group && (isGroupOwner(group) || isGroupMember(group) || isGroupInvite(group));
    }).sort(function (a, b) {
      return String(a.name || "").localeCompare(String(b.name || ""), undefined, { sensitivity: "base" });
    });
  }

  function isGroupOwner(group) {
    return !!(group && group.ownerDeviceId && group.ownerDeviceId === state.deviceId);
  }

  function isGroupMember(group) {
    return !!(group && group.members && group.members[state.deviceId]);
  }

  function isGroupInvite(group) {
    const selfKey = getNicknameKey();
    return !!(group && group.invites && group.invites[selfKey]);
  }

  function getDefaultGroupId() {
    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });
    return groups.length ? groups[0].id : "";
  }

  function renderChannelInfo() {
    if (!els.channelInfo) {
      return;
    }
    if (state.activeChannel === "dm") {
      if (state.dmTargetNickname) {
        els.channelInfo.textContent = "Direct messages to " + state.dmTargetNickname + ". Only you and the recipient can see these if the recipient matches.";
      } else {
        els.channelInfo.textContent = "Direct Message mode: type a nickname to send a private message.";
      }
      return;
    }
    if (state.activeChannel === "group") {
      const group = state.activeGroupId ? normalizeGroupRecord(state.activeGroupId, state.groups[state.activeGroupId]) : null;
      if (group && isGroupMember(group)) {
        els.channelInfo.textContent = "Group chat: " + group.name + ". Messages are visible only inside this group.";
      } else if (group && isGroupInvite(group)) {
        els.channelInfo.textContent = "You have an invite for " + group.name + ". Accept it from the group menu.";
      } else {
        els.channelInfo.textContent = "Group chat mode: select a group or create one to begin.";
      }
      return;
    }
    els.channelInfo.textContent = "Public chat: all users can see messages here.";
  }

  function updateGroupSelectOptions() {
    if (!els.groupSelect) {
      return;
    }
    const groups = getCurrentUserGroups().filter(function (group) {
      return isGroupOwner(group) || isGroupMember(group);
    });
    if (!groups.length) {
      els.groupSelect.innerHTML = '<option value="">No groups available</option>';
      els.groupSelect.disabled = true;
      return;
    }
    const html = [
      '<option value="">Choose a group...</option>'
    ].concat(groups.map(function (group) {
      return '<option value="' + escapeAttribute(group.id) + '">' + escapeHtml(group.name || "Unnamed group") + '</option>';
    }));
    els.groupSelect.innerHTML = html.join("");
    els.groupSelect.disabled = false;
    if (state.activeGroupId && groups.some(function (group) { return group.id === state.activeGroupId; })) {
      els.groupSelect.value = state.activeGroupId;
    } else {
      state.activeGroupId = groups.length ? groups[0].id : "";
      els.groupSelect.value = state.activeGroupId;
    }
  }

